  db:
    image: postgres:16-alpine
    container_name: db
    restart: {{ services_restart_policy }}
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: root
      POSTGRES_DB: postgres
      DB_NAMESPACE: auth
    networks:
      - studio
    ports:
      - "5432:5432"
    volumes:
      - db:/var/lib/postgresql/data
      - ./projects/auth/init_postgres.sh:/docker-entrypoint-initdb.d/init.sh
